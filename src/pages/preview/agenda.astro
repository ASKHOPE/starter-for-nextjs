---
import Layout from '../../layouts/Layout.astro';
import { PreviewAgenda } from '../../components/pages/PreviewAgenda';

const id = Astro.url.searchParams.get('id');
---

<Layout title="Program Preview">
  {id ? (
    <PreviewAgenda client:load agendaId={id} />
  ) : (
    <div class="flex items-center justify-center min-h-[60vh] text-on-surface-variant font-bold">
      No Agenda Selected
    </div>
  )}
</Layout>
